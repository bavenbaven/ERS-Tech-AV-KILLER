[USB_Install]
Include = setupapi.inf
Needs = ClassInstall32.Services

[USB_Install.Services]
Include = setupapi.inf
Needs = ClassInstall32.Services

[USB_Install.Wdf]
KmdfService = WINUSB, WinUSB_Install

[WinUSB_Install]
KmdfLibraryVersion = 1.11

[WinUSB_Install.Services]
AddService = WinUSB, 0x00000002, WinUSB_ServiceInstaller

[WinUSB_ServiceInstaller]
DisplayName    = %WinUSB_SvcDesc%
ServiceType    = 1
StartType      = 3
ErrorControl   = 1
ServiceBinary  = %12%\WinUSB.sys

[WinUSB_Install.HW]
AddReg = WinUSB_AddReg

[WinUSB_AddReg]
HKR,,NTMPDriver,,%12%\WinUSB.sys
HKR,,DeviceInterfaceGUID,,"{0EAD355B-A7E8-4F6F-82E7-4312C410EF2E}"
HKR,,"Parameters","MaximumPacketSize",0x10001,4096

[USB_Install.CopyFiles]
AdbWinApi.dll
AdbWinUsbApi.dll

[USB_Install.Devices]
AddService = AndroidUsbDeviceClass,, AndroidUsbDeviceClass_Service_Inst

[AndroidUsbDeviceClass_Service_Inst]
DisplayName    = %AndroidUsbDeviceClass_Service%
ServiceType    = 1
StartType      = 3
ErrorControl   = 0
ServiceBinary  = %12%\AndroidUsbDeviceClass.sys

[Strings]
ProviderName                    = "ERS Tech"
WinUSB_SvcDesc                  = "Android ADB Interface (ERS Tech)"
AndroidUsbDeviceClass_Service   = "Android USB Device Class"
DiskName                        = "ERS Tech AV Killer Driver"

