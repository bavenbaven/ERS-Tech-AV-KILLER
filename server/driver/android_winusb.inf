[Version]
Signature           = "$WINDOWS NT$"
Class               = AndroidUsbDeviceClass
ClassGuid           = {3F966BD9-FA04-4ec5-991C-D326FC672C8E}
Provider            = %ProviderName%
DriverVer=01/01/2025,12.0.0.0
CatalogFile         = android.cat

[ClassInstall32]
AddReg = AndroidUsbDeviceClass_AddReg

[AndroidUsbDeviceClass_AddReg]
HKR,,,,"Android USB Devices"
HKR,,Icon,,-1

[DestinationDirs]
AndroidUsbDeviceClass_CopyFiles = 13

[SourceDisksNames]
1 = %DiskName%,,,

[SourceDisksFiles]
AdbWinApi.dll = 1
AdbWinUsbApi.dll = 1

[Manufacturer]
%ProviderName% = Google, NTx86, NTamd64, NTarm64

